# Cloudflare Credentials
# Copy this file to .env.local and populate with your values.
# Never commit .env.local to source control.

# Found at: dash.cloudflare.com → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=

# Found at: dash.cloudflare.com → select your account → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# Found at: dash.cloudflare.com → select your zone → right sidebar
CLOUDFLARE_ZONE_ID=

# Your domain (e.g. acmecorp.dev)
CLOUDFLARE_DOMAIN=
