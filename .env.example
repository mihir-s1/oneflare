# ─────────────────────────────────────────────────────────────────────────────
# OneFlare lab — environment configuration
# Copy this file to .env.local and fill in your values. NEVER commit .env.local.
#   cp .env.example .env.local
# .env.local is gitignored. Everything marked SENSITIVE is a secret — keep it out
# of source control, screenshots, and shared docs.
# ─────────────────────────────────────────────────────────────────────────────

# == Cloudflare — required to PROVISION your NFR (cloudflare/setup.sh, deploys) ==
# dash.cloudflare.com → My Profile → API Tokens. Scopes: Account (Workers Scripts:Edit,
# Cloudflare Containers:Edit, Account Rulesets:Edit, Access:Edit, Zero Trust:Edit,
# Logs:Edit), Zone (Zone:Read, WAF:Edit, DNS:Edit, Logs:Edit) for your zone.
CLOUDFLARE_API_TOKEN=                 # SENSITIVE
# dash.cloudflare.com → your account → right sidebar
CLOUDFLARE_ACCOUNT_ID=                # account-identifying
# dash.cloudflare.com → your zone → right sidebar
CLOUDFLARE_ZONE_ID=                   # account-identifying
# Your zone/apex domain (e.g. example.com). setup.sh binds shop/portal/api.<domain>.
CLOUDFLARE_DOMAIN=

# == Attack targeting (non-sensitive) — the lab-ui backend also reads LAB_* below ==
# Gateway DoH endpoint for the DNS-tunneling scenario. one.dash.cloudflare.com →
# Networks → Resolvers & Proxies → DNS locations → [your location] → DNS over HTTPS.
# Use the hex-subdomain URL (NOT your team name), else queries aren't logged.
CF_GATEWAY_DOH_URL=                   # https://<hex-id>.cloudflare-gateway.com/dns-query
# Access portal allow-list email domain (setup.sh). Defaults to novamind.ai.
ACCESS_EMAIL_DOMAIN=

# == lab-ui server-side defaults (GET /api/config) — make the console zero-config ==
# These persist server-side so anyone hitting the console can run scenarios. All
# non-sensitive. LAB_CF_DOMAIN defaults to one-flare.com in code; set it to YOUR
# domain so the console targets your NFR.
LAB_CF_DOMAIN=                        # e.g. example.com (falls back to CLOUDFLARE_DOMAIN intent)
LAB_SHOP_URL=                         # optional; else https://shop.<LAB_CF_DOMAIN>
LAB_PORTAL_URL=                       # optional; else https://portal.<LAB_CF_DOMAIN>
LAB_API_URL=                          # optional; else https://api.<LAB_CF_DOMAIN>
LAB_GATEWAY_DOH_URL=                  # optional; server default for the DNS scenario
LAB_ATTACK_DELAY=0.5                  # base per-request delay (seconds)
LAB_ATTACK_JITTER=0.3                 # added random jitter (seconds)
LAB_S1_CONSOLE_URL=                   # display-only; your SentinelOne console URL

# == Lab app credentials (worker secrets; defaults exist for the mock apps) ==
PORTAL_USERNAME=                      # SENSITIVE-ish (lab creds)
PORTAL_PASSWORD=                      # SENSITIVE-ish
API_USERNAME=                         # SENSITIVE-ish
API_PASSWORD=                         # SENSITIVE-ish
INCIDENT_KEY=                         # optional incident-webhook key

# == SentinelOne — needed to INGEST logs + (optionally) deploy detections ==
# Console host, no trailing slash, e.g. https://usea1-yourtenant.sentinelone.net
S1_CONSOLE_URL=
S1_CONSOLE_API_TOKEN=                 # SENSITIVE (Mgmt REST / LRQ / SDL)
# HEC ingest endpoint + token (Logpush destination / sample ingest)
S1_HEC_INGEST_URL=
S1_HEC_INGEST_TOKEN=                  # SENSITIVE
