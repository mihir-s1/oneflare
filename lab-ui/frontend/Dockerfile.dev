# syntax=docker/dockerfile:1
# Local-only multi-stage build: compile the Vite SPA INSIDE Docker, then serve
# with nginx. Lets `docker compose up --build` work on a machine with no Node.
# Not used in production (the prod Dockerfile expects a host-built ./dist).
FROM node:22-slim AS build
WORKDIR /app
ENV NODE_ENV=development
COPY package.json package-lock.json ./
# The Docker->npm-registry connection here is flaky (ECONNRESET). --maxsockets=1
# serialises downloads to one connection so the unstable network doesn't get
# overwhelmed (npm's parallel fetch was crashing with "Exit handler never
# called"). The cache mount persists /root/.npm across attempts so a rebuild
# resumes from what already downloaded. `npm install` re-resolves platform
# optional deps (rollup/esbuild linux-arm64) and installs devDeps (vite).
RUN --mount=type=cache,target=/root/.npm \
    npm install --include=dev --no-audit --no-fund \
      --maxsockets=1 --fetch-timeout=600000 --loglevel=error \
 && test -x node_modules/.bin/vite
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
